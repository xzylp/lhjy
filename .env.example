# ashare-system-v2 环境变量
ASHARE_ENV=dev
ASHARE_RUN_MODE=dry-run
ASHARE_EXECUTION_MODE=mock
# 执行平面默认走 Windows Execution Gateway，不假设 Linux 本地下单
ASHARE_EXECUTION_PLANE=windows_gateway
ASHARE_MARKET_MODE=mock
ASHARE_STORAGE_ROOT=.ashare_state
ASHARE_LOGS_DIR=logs

# Windows Execution Gateway 主备固定口径（部署与上报统一复用）
# 主：source_id=windows-vm-a, deployment_role=primary_gateway
#     bridge_path=linux_openclaw -> windows_gateway -> qmt_vm
# 备：source_id=windows-vm-b, deployment_role=backup_gateway
#     bridge_path=linux_openclaw -> windows_gateway_backup -> qmt_vm

# XtQuant (QMT)
ASHARE_XTQUANT_ROOT=../XtQuant
ASHARE_XTQUANTSERVICE_ROOT=../xtquantservice
ASHARE_XTQUANT_USERDATA=D:\国金证券QMT交易端\userdata_mini
ASHARE_XTQUANT_ACCOUNT_ID=8890130545
ASHARE_XTQUANT_SESSION_ID=323456
ASHARE_XTQUANT_ACCOUNT_TYPE=STOCK

# 策略参数
ASHARE_MIN_CONFIDENCE=0.55
ASHARE_STRATEGY_NAME=ashare-system-v2

# 服务
ASHARE_SERVICE_HOST=127.0.0.1
ASHARE_SERVICE_PORT=8100
ASHARE_SERVICE_PROBE_TIMEOUT_SEC=3.0
# 可选：给 Windows Gateway / 外部接线包输出一个稳定的 Linux 可达地址
# ASHARE_PUBLIC_BASE_URL=http://192.168.99.16:8100

# 可选：显式指定 Linux/WSL 使用的 Python 与 OpenClaw 可执行文件
# Ubuntu Server 常见值：
# ASHARE_PYTHON_BIN=/srv/projects/ashare-system-v2/.venv/bin/python
# OPENCLAW_BIN=/home/yxz/.npm-global/bin/openclaw
# OPENCLAW_GATEWAY_BIND=lan
# OPENCLAW_GATEWAY_PORT=18890
# OPENCLAW_GATEWAY_ALLOW_UNCONFIGURED=true

# 通知
ASHARE_FEISHU_WEBHOOK_URL=
ASHARE_FEISHU_APP_ID=
ASHARE_FEISHU_APP_SECRET=
ASHARE_FEISHU_CHAT_ID=
ASHARE_FEISHU_CONTROL_PLANE_BASE_URL=http://127.0.0.1:8100
ASHARE_ALERTS_ENABLED=false

# Hermes 模型路由
ASHARE_HERMES_ROUTING_POLICY=half_minimax_half_compat
ASHARE_HERMES_MODEL_DEFAULT=MiniMax-M2.7
ASHARE_HERMES_MODEL_FAST=MiniMax-M2.7
ASHARE_HERMES_MODEL_DEEP=gpt-5.4
ASHARE_HERMES_MODEL_EXECUTION=gpt-5.4
ASHARE_HERMES_MINIMAX_PROVIDER_NAME=MiniMax
ASHARE_HERMES_MINIMAX_MODEL=MiniMax-M2.7
# 若 MiniMax 由外部 Hermes profile 托管，可不在这里重复放密钥
# ASHARE_HERMES_MINIMAX_BASE_URL=
# ASHARE_HERMES_MINIMAX_API_KEY=
ASHARE_HERMES_COMPAT_PROVIDER_NAME=Chunfeng
# ASHARE_HERMES_COMPAT_BASE_URL=https://your-openai-compatible-endpoint/v1
# ASHARE_HERMES_COMPAT_API_KEY=sk-xxx
ASHARE_HERMES_COMPAT_MODEL=gpt-5.4
