    {
      "id": "ashare",
      "display_name": "南风·量化",
      "model": "GPT-5.4",
      "prompt_file": "openclaw/prompts/ashare.txt",
      "outputs": ["plan", "handoff_order", "system_home", "system_overview", "deployment_gate", "paper_validation_day", "paper_validation", "rollout_bootstrap_execution", "rollout_gate_summary", "final_report"]
    },
